// Prisma schema for metadata_app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  images          Image[]
  metadataResults MetadataResult[]

  @@map("users")
}

// Image model
model Image {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  filename  String
  filepath  String
  mimetype  String
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("images")
}

// Metadata Result model
model MetadataResult {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  imageUrl            String   @map("image_url")
  contextInput        String   @map("context_input")
  seoTitle            String   @map("seo_title")
  metaDescription     String   @map("meta_description")
  altText             String   @map("alt_text")
  socialCaption       String   @map("social_caption")
  recommendedChannel  String   @map("recommended_channel")
  channelExplanation  String   @map("channel_explanation")
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("metadata_results")
}
